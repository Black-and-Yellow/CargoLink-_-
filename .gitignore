# Ignore Node modules (all packages)
node_modules/
**/node_modules/

# Build outputs
/dist/
/build/
**/dist/
**/build/

# Vite cache
/.vite/
**/.vite/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Env files
.env
.env.*
!.env.example

# Allow GCP deployment YAML files (secrets are in Secret Manager, not in these files)
# *.yaml and *.yml are NOT ignored so cloudbuild.yaml, app.yaml, dispatch.yaml get committed

# OS junk
.DS_Store
Thumbs.db

# Editor settings
.vscode/
.idea/

# Test coverage
coverage/
**/coverage/

playwright-report/
/playwright-report/
**/playwright-report/**

test-results/
**/test-results/**
/test-results/

# Backend logs
backend/logs/
*.log

# Logs (anywhere)
logs/
**/logs/

# Uploads (anywhere)
uploads/
**/uploads/

# Common backend upload locations
backend/uploads/
backend/public/uploads/
